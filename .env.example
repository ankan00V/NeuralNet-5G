APP_MODE=demo
MONGODB_URI=
MONGODB_DB=neuralnet5g

MODEL_PATH=model/lstm_fault.pt
SCALER_PATH=model/scaler.pkl

CORS_ORIGINS=https://neuralnet5g.test
WS_BROADCAST_INTERVAL=5

AUTH_ENABLED=true
AUTH_JWT_SECRET=replace-with-strong-jwt-secret
AUDIT_SIGNING_KEY=replace-with-strong-audit-signing-key
AUTH_JWT_EXP_MINUTES=60
AUTH_COOKIE_NAME=nn5g_access
AUTH_COOKIE_SECURE=false
REQUIRE_WEBSOCKET_AUTH=true
# AUTH_USERS_JSON=[{"email":"ops@example.com","name":"NOC Lead","role":"admin","tenant":"*","password_hash":"plain:replace-me"}]

ENABLE_DEV_ENDPOINTS=false
INGESTION_MODE=simulator
INGESTION_API_KEYS=
TELEMETRY_MIN_ACTIVE_TOWERS=0
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=2.0

MAX_REQUEST_BYTES=256000
RATE_LIMIT_PER_MINUTE=240
RATE_LIMIT_BURST=60

ENABLE_FORECAST_ENDPOINT=false
FAULT_OPEN_PROB_THRESHOLD=0.5

ENFORCE_MODEL_GATE=false
MODEL_MIN_MACRO_F1=0.60
MODEL_MIN_CLASS_F1=0.50
